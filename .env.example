# Trakt — create an app at https://trakt.tv/oauth/applications/new
# Set "Redirect URI" to: urn:ietf:wg:oauth:2.0:oob
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret

# MAL — create an app at https://myanimelist.net/apiconfig
# Set "App Redirect URL" to: http://localhost:8080/callback
MAL_CLIENT_ID=your_mal_client_id
MAL_CLIENT_SECRET=your_mal_client_secret
